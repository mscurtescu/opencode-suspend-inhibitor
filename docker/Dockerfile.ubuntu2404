# Ubuntu 24.04 LTS — gnome-session-inhibit via gnome-session-bin
# Build: task container:build
# Run:   task docker:shell

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    dbus \
    dbus-x11 \
    gnome-session-bin \
  && rm -rf /var/lib/apt/lists/* \
  && curl -fsSL https://opencode.ai/install | bash \
  && ln -sf /root/.opencode/bin/opencode /usr/local/bin/opencode

RUN mkdir -p /root/.config/opencode
COPY opencode.jsonc /root/.config/opencode/opencode.jsonc

WORKDIR /workspace
ENV PATH="/root/.opencode/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

CMD ["opencode", "serve", "--port", "4096", "--hostname", "0.0.0.0", "--print-logs"]